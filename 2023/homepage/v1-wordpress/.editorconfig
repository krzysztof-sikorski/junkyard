root = true

[*]
charset = utf-8
end_of_line = LF
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 80

[*.php]
# settings required by PSR-12 standard
end_of_line = LF
indent_style = space
indent_size = 4
max_line_length = 120

[Makefile]
indent_style = tab
max_line_length = unset

[bedrock/**] # vendored files
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
max_line_length = unset
